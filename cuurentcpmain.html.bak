const heroImg = document.querySelector('#dynamic-hero img');
const hour = new Date().getHours();
const collectionUrl = 'https://www.christpath.net/fear-not?format=json&limit=100';
const collectionUrl2 = 'https://www.christpath.net/mary-magdalene?format=json';
const videoCollectionUrl = 'https://www.christpath.net/videos?format=json'; 
