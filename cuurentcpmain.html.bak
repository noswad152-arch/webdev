<body>
     <style>

.bible-search .bs-verse-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8px;
}

.bible-search .bs-verse-flags {
  display: flex;
  align-items: center;
  gap: 6px;
  flex-wrap: wrap;
}

.bible-search .bs-chip {
  font-size: 11px;
  line-height: 1;
  padding: 5px 8px;
  border-radius: 999px;
  border: 1px solid rgba(255, 255, 255, 0.22);
  color: #efe6d7;
  background: rgba(15, 18, 33, 0.6);
}

.bible-search .bs-chip.primary {
  border-color: rgba(251, 174, 1, 0.7);
  color: #ffe8b2;
  background: rgba(251, 174, 1, 0.16);
  font-weight: 700;
}

.bible-search .bs-cluster-signal {
  margin-top: 10px;
  padding: 10px;
  border-radius: 10px;
  border: 1px solid rgba(255, 255, 255, 0.1);
  background:
    linear-gradient(180deg, rgba(255,255,255,0.04), rgba(255,255,255,0.02)),
    radial-gradient(circle at 0% 50%, rgba(122,167,255,0.12), transparent 40%);
}

.bible-search .bs-cluster-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10px;
  margin-bottom: 8px;
}

.bible-search .bs-cluster-title {
  font-size: 11px;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--text-subtle, #b8aa94);
}

.bible-search .bs-cluster-score {
  font-size: 12px;
  font-weight: 700;
  color: #dce8ff;
}

.bible-search .bs-cluster-bar {
  height: 10px;
  border-radius: 999px;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.08);
  box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.06);
}

.bible-search .bs-cluster-fill {
  height: 100%;
  border-radius: 999px;
  background: linear-gradient(90deg, #5eead4 0%, #7aa7ff 45%, #f6bf57 100%);
  box-shadow: 0 0 18px rgba(122,167,255,0.28);
}

.bible-search .bs-cluster-meta {
  margin-top: 7px;
  font-size: 11px;
  color: var(--text-subtle, #b8aa94);
}

.bible-search .bs-cluster-lines {
  margin-top: 8px;
  font-size: 12px;
  line-height: 1.45;
  color: var(--text-subtle, #b8aa94);
}

#bible-search #searchQuery {
  width: 100%;
  max-width: 100%;
  box-sizing: border-box;
}
</style>
